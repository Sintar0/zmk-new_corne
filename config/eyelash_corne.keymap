/*
 * Keymap ZMK pour Eyelash Corne — Ergol (disposition système Linux)
 *
 * IMPORTANT : Ce clavier est configuré en QWERTY physique.
 * La disposition Ergol est gérée par le driver Linux (xkb).
 * Ne pas programmer les lettres Ergol ici — configurer uniquement
 * les touches spéciales, modificateurs et couches.
 *
 * Couches :
 *   0 = BASE     → QWERTY (le driver Linux affiche Ergol)
 *   1 = NAVNUM   → Navigation + Pavé numérique (recommandé Ergol)
 *   2 = FN       → F1–F12 + touches media
 *   3 = BT       → Gestion Bluetooth
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

// ─── Raccourcis lisibilité ────────────────────────────────────────────────────
#define BASE   0
#define NAVNUM 1
#define FN     2
#define BT_LYR 3

// Touches pouce gauche
#define T_NAV  &mo NAVNUM   // hold → NavNum
#define T_FN   &mo FN       // hold → Fn

// Touches pouce droit
#define T_AGR  &kp RALT     // AltGr — INDISPENSABLE pour les symboles Ergol
#define T_BT   &mo BT_LYR   // hold → Bluetooth

// ─── Comportements personnalisés ──────────────────────────────────────────────
/ {
    behaviors {
        /*
         * hm = Homerow Mod (optionnel, désactivé par défaut)
         * Décommenter si vous souhaitez ajouter des homerow mods plus tard.
         * Pour débuter avec Ergol sur 3×6, ils ne sont pas nécessaires.
         */
        // hm: homerow_mods {
        //     compatible = "zmk,behavior-hold-tap";
        //     #binding-cells = <2>;
        //     tapping-term-ms = <200>;
        //     quick-tap-ms = <0>;
        //     flavor = "tap-preferred";
        //     bindings = <&kp>, <&kp>;
        // };

        /*
         * Tap-dance : double tap sur Échap → retour layer BASE
         * Utile si on se retrouve coincé dans une couche
         */
        td_esc: tap_dance_esc {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp ESC>, <&to BASE>;
        };
    };

    // ─── KEYMAP ───────────────────────────────────────────────────────────────
    keymap {
        compatible = "zmk,keymap";

        // ── Couche 0 : BASE (QWERTY physique → Ergol via driver Linux) ────────
        //
        //  Le driver Linux transforme ces codes QWERTY en Ergol.
        //  Ex : tu appuies sur Q physique → le PC reçoit Q → Ergol affiche É
        //
        //  Disposition physique (ce que ZMK envoie) :
        //  ┌───┬───┬───┬───┬───┬───┐     ┌───┬───┬───┬───┬───┬───┐
        //  │TAB│ Q │ W │ E │ R │ T │     │ Y │ U │ I │ O │ P │BSP│
        //  ├───┼───┼───┼───┼───┼───┤     ├───┼───┼───┼───┼───┼───┤
        //  │CTL│ A │ S │ D │ F │ G │     │ H │ J │ K │ L │ ; │ ' │
        //  ├───┼───┼───┼───┼───┼───┤     ├───┼───┼───┼───┼───┼───┤
        //  │SFT│ Z │ X │ C │ V │ B │     │ N │ M │ , │ . │ / │SFT│
        //  └───┴───┴───┴───┴───┴───┘     └───┴───┴───┴───┴───┴───┘
        //                  ┌───┬───┬───┐ ┌───┬───┬───┐
        //                  │GUI│NAV│SPC│ │ENT│AGR│ BT│
        //                  └───┴───┴───┘ └───┴───┴───┘
        //
        //  Ce que tu tapes en Ergol (grâce au driver Linux) :
        //  ┌───┬───┬───┬───┬───┬───┐     ┌───┬───┬───┬───┬───┬───┐
        //  │TAB│ é │ « │ p │ o │ è │     │ v │ d │ l │ j │ z │BSP│
        //  ├───┼───┼───┼───┼───┼───┤     ├───┼───┼───┼───┼───┼───┤
        //  │CTL│ a │ u │ i │ e │ , │     │ c │ t │ s │ r │ n │ m │
        //  ├───┼───┼───┼───┼───┼───┤     ├───┼───┼───┼───┼───┼───┤
        //  │SFT│ à │ y │ x │ · │ k │     │ ' │ q │ g │ h │ f │SFT│
        //  └───┴───┴───┴───┴───┴───┘     └───┴───┴───┴───┴───┴───┘
        //                  ┌───┬───┬───┐ ┌───┬───┬───┐
        //                  │GUI│NAV│SPC│ │ENT│AGR│ BT│
        //                  └───┴───┴───┘ └───┴───┴───┘
        //
        base_layer {
            display-name = "BASE";
            bindings = <
                &kp TAB   &kp Q  &kp W  &kp E  &kp R  &kp T        &kp Y  &kp U  &kp I     &kp O   &kp P    &kp BSPC
                &kp LCTRL &kp A  &kp S  &kp D  &kp F  &kp G        &kp H  &kp J  &kp K     &kp L   &kp SEMI &kp SQT
                &kp LSHFT &kp Z  &kp X  &kp C  &kp V  &kp B        &kp N  &kp M  &kp COMMA &kp DOT &kp FSLH &kp RSHFT
                                 &kp LGUI  T_NAV  &kp SPACE        &kp RET  T_AGR  T_BT
            >;
        };

        // ── Couche 1 : NAVNUM (Navigation + Pavé numérique) ──────────────────
        //
        //  Recommandée par Ergol pour 3×6 : une seule couche pour tout.
        //  Inspirée du schéma NavNum officiel d'Ergol.
        //
        //  ┌───┬───┬───┬───┬───┬───┐     ┌───┬───┬───┬───┬───┬───┐
        //  │ESC│   │   │   │   │   │     │ / │ 7 │ 8 │ 9 │ - │DEL│
        //  ├───┼───┼───┼───┼───┼───┤     ├───┼───┼───┼───┼───┼───┤
        //  │CTL│   │HOM│PGD│PGU│END│     │ * │ 4 │ 5 │ 6 │ + │ = │
        //  ├───┼───┼───┼───┼───┼───┤     ├───┼───┼───┼───┼───┼───┤
        //  │SFT│   │   │   │   │   │     │ 0 │ 1 │ 2 │ 3 │ . │ENT│
        //  └───┴───┴───┴───┴───┴───┘     └───┴───┴───┴───┴───┴───┘
        //                  ┌───┬───┬───┐ ┌───┬───┬───┐
        //                  │   │[■]│   │ │   │   │FN │
        //                  └───┴───┴───┘ └───┴───┴───┘
        //
        //  Note : les flèches ←↓↑→ sont sur H/J/K/L comme Vim
        //  (cohérent avec Ergol où c/t/s/r = ←↓↑→ dans la position Vim)
        //
        navnum_layer {
            display-name = "NAVNUM";
            bindings = <
                &td_esc  &none    &none    &none    &none    &none        &kp KP_SLASH    &kp N7  &kp N8  &kp N9  &kp MINUS  &kp DEL
                &kp LCTRL &none   &kp HOME &kp PG_DN &kp PG_UP &kp END  &kp KP_ASTERISK &kp N4  &kp N5  &kp N6  &kp PLUS   &kp EQUAL
                &kp LSHFT &none   &kp LEFT &kp DOWN  &kp UP   &kp RIGHT  &kp N0          &kp N1  &kp N2  &kp N3  &kp DOT    &kp RET
                                  &kp LGUI  &trans  &kp SPACE            &kp RET         &trans  &mo FN
            >;
        };

        // ── Couche 2 : FN (Touches de fonction + Media) ───────────────────────
        //
        //  ┌───┬───┬───┬───┬───┬───┐     ┌───┬───┬───┬───┬───┬───┐
        //  │   │F1 │F2 │F3 │F4 │F5 │     │F6 │F7 │F8 │F9 │F10│   │
        //  ├───┼───┼───┼───┼───┼───┤     ├───┼───┼───┼───┼───┼───┤
        //  │   │   │MUT│VOL│VOL│   │     │   │   │   │F11│F12│   │
        //  │   │   │   │ - │ + │   │     │   │   │   │   │   │   │
        //  ├───┼───┼───┼───┼───┼───┤     ├───┼───┼───┼───┼───┼───┤
        //  │   │   │PRV│PLY│NXT│   │     │   │   │   │   │PSC│   │
        //  └───┴───┴───┴───┴───┴───┘     └───┴───┴───┴───┴───┴───┘
        //                  ┌───┬───┬───┐ ┌───┬───┬───┐
        //                  │   │   │   │ │   │   │[■]│
        //                  └───┴───┴───┘ └───┴───┴───┘
        fn_layer {
            display-name = "FN";
            bindings = <
                &none  &kp F1  &kp F2       &kp F3       &kp F4       &kp F5        &kp F6  &kp F7  &kp F8  &kp F9  &kp F10  &none
                &none  &none   &kp C_MUTE   &kp C_VOL_DN &kp C_VOL_UP &none         &none   &none   &none   &kp F11 &kp F12  &none
                &none  &none   &kp C_PREV   &kp C_PP     &kp C_NEXT   &none         &none   &none   &none   &none   &kp PSCRN &none
                               &none  &none  &none                                   &none   &none   &trans
            >;
        };

        // ── Couche 3 : BT (Bluetooth) ─────────────────────────────────────────
        //
        //  ┌───┬───┬───┬───┬───┬───┐     ┌───┬───┬───┬───┬───┬───┐
        //  │   │BT0│BT1│BT2│BT3│BT4│     │   │   │   │   │   │   │
        //  ├───┼───┼───┼───┼───┼───┤     ├───┼───┼───┼───┼───┼───┤
        //  │   │   │   │   │   │   │     │   │   │   │   │   │   │
        //  ├───┼───┼───┼───┼───┼───┤     ├───┼───┼───┼───┼───┼───┤
        //  │   │CLR│   │   │   │   │     │   │   │   │   │   │   │
        //  └───┴───┴───┴───┴───┴───┘     └───┴───┴───┴───┴───┴───┘
        //                  ┌───┬───┬───┐ ┌───┬───┬───┐
        //                  │USB│   │BLE│ │   │   │[■]│
        //                  └───┴───┴───┘ └───┴───┴───┘
        //
        //  BT0–BT4 : sélectionner un des 5 profils Bluetooth
        //  CLR     : effacer le profil Bluetooth actuel (en cas de bug)
        //  USB/BLE : forcer la sortie USB ou Bluetooth
        //
        bt_layer {
            display-name = "BT";
            bindings = <
                &none  &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4    &none  &none  &none  &none  &none  &none
                &none  &none         &none         &none         &none         &none             &none  &none  &none  &none  &none  &none
                &none  &bt BT_CLR    &none         &none         &none         &none             &none  &none  &none  &none  &none  &none
                                     &out OUT_USB  &none  &out OUT_BLE                          &none  &none  &trans
            >;
        };
    };
};
